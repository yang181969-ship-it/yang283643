              <img src="./assets/animes/majo-cover.webp" alt="魔女之旅" loading="lazy">
              <span class="anime-badge ongoing">连载中</span>
            </div>
            <p>魔女之旅</p>
          </a>
        </div>

        <div class="anime-item">
          <a href="./html/anime-detail.html?id=frieren" class="anime-card">

<main id="main-content">
  <section class="no-card">

    <div class="anime-hero">
      <h2 class="page-title">动漫</h2>
      <p class="page-desc">记录我看过和想看的动漫作品。</p>
    </div>

    <div class="anime-tabs">
      <button type="button" data-target="watched" class="active">已看的动漫</button>
      <button type="button" data-target="wishlist">想看的动漫</button>
    </div>

    <section id="watched" class="anime-section active">
      <h2>已看的动漫</h2>
      <div class="anime-gallery">
        <div class="anime-item">
          <a href="./html/anime-detail.html?id=majo" class="anime-card">

        </div>

        <div class="anime-item">
          <a href="./html/anime-detail.html?id=spy" class="anime-card">
            <div class="anime-image-wrapper">
              <img src="./assets/animes/spy-cover.webp" alt="间谍过家家" loading="lazy">
              <span class="anime-badge ongoing">连载中</span>
            </div>
            <p>间谍过家家</p>
          </a>
        </div>

        <div class="anime-item">
          <a href="./html/anime-detail.html?id=titan" class="anime-card">
            <div class="anime-image-wrapper">
              <img src="./assets/animes/titan-cover.jpg" alt="进击的巨人" loading="lazy">
              <span class="anime-badge finished">已完结</span>
            </div>
            <p>进击的巨人</p>
          </a>
        </div>

        <div class="anime-item">
          <a href="./html/anime-detail.html?id=datebattle" class="anime-card">
            <div class="anime-image-wrapper">
              <img src="./assets/animes/datebattle-cover.jpg" alt="约会大作战" loading="lazy">
              <span class="anime-badge finished">已完结</span>
            </div>
            <p>约会大作战</p>
          </a>
        </div>

         <div class="anime-item">
          <a href="./html/anime-detail.html?id=suzuya" class="anime-card">
            <div class="anime-image-wrapper">
              <img src="./assets/animes/suzuya-cover.jpg" alt="铃芽之旅" loading="lazy">
              <span class="anime-badge finished">已完结</span>
            </div>
            <p>铃芽之旅</p>
          </a>
        </div>
      </div>
    </section>

    <section id="wishlist" class="anime-section">
      <h2>想看的动漫</h2>
      <div class="anime-gallery">

        <div class="anime-item">
          <a href="./html/anime-detail.html?id=garden" class="anime-card">
